{
    "name": "dot-agents-marketplace",
    "private": true,
    "version": "1.0.0",
    "description": "Multi-CLI marketplace packaging for Nexus Orchestrator",
    "license": "MIT",
    "type": "module",
    "packageManager": "bun@1.3.3",
    "scripts": {
        "versions:sync": "bun scripts/sync-versions.ts",
        "versions:check": "bun scripts/sync-versions.ts --check",
        "validate": "bun scripts/validate-multicli.ts",
        "build": "bun scripts/build-multicli.ts",
        "ci": "bun run versions:check && bun run validate && bun run build"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5.9.2"
    },
    "module": "index.ts"
}